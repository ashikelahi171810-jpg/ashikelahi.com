---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const services = [
  {
    icon: '🖥️',
    title: 'Web Development',
    desc: 'Clean, fast, responsive websites built with modern frameworks like Astro, React, and Next.js.',
  },
  {
    icon: '🎨',
    title: 'UI / UX Design',
    desc: 'Pixel-perfect interfaces with great user experience, accessibility, and attention to detail.',
  },
  {
    icon: '⚙️',
    title: 'Backend & APIs',
    desc: 'Robust server-side logic, REST APIs, and database design with Node.js, PHP, and Python.',
  },
  {
    icon: '🚀',
    title: 'Performance',
    desc: 'Speed optimisation, Core Web Vitals improvements, and efficient deployment pipelines.',
  },
  {
    icon: '🛒',
    title: 'E-Commerce',
    desc: 'Custom shopping experiences using WooCommerce, Stripe, and modern payment integrations.',
  },
  {
    icon: '🔒',
    title: 'Security',
    desc: 'Secure authentication, data validation, and following OWASP best practices throughout.',
  },
];

const stats = [
  { value: '20+', label: 'Projects Completed' },
  { value: '15+', label: 'Happy Clients' },
  { value: '3+', label: 'Years Experience' },
  { value: '99%', label: 'Client Satisfaction' },
];

const skills = [
  { name: 'HTML & CSS', level: 95 },
  { name: 'JavaScript', level: 88 },
  { name: 'TypeScript', level: 78 },
  { name: 'React', level: 82 },
  { name: 'Astro', level: 85 },
  { name: 'Node.js', level: 75 },
  { name: 'PHP', level: 72 },
  { name: 'MySQL', level: 78 },
  { name: 'Git & GitHub', level: 90 },
  { name: 'Tailwind CSS', level: 92 },
  { name: 'Figma', level: 70 },
  { name: 'Docker', level: 60 },
];

const projects = [
  {
    tag: 'Astro · Tailwind',
    title: 'Personal Portfolio',
    desc: 'This very site — a fast, modern portfolio and blog built with Astro and deployed on GitHub Pages.',
    github: 'https://github.com/ashikelahi171810-jpg/ashikelahi.com',
    live: '#',
    color: '#7c3aed',
  },
  {
    tag: 'React · Node.js',
    title: 'Project Two',
    desc: 'A full-stack web application. Update this with your real project description and links.',
    github: '#',
    live: '#',
    color: '#2563eb',
  },
  {
    tag: 'PHP · MySQL',
    title: 'Project Three',
    desc: 'A backend-heavy project. Update this with your real project description and links.',
    github: '#',
    live: '#',
    color: '#059669',
  },
];

const faqs = [
  {
    q: 'What types of projects do you take on?',
    a: 'I work on a wide range of web projects — from personal portfolios and landing pages to full-stack applications and e-commerce stores.',
  },
  {
    q: 'How do you handle project timelines?',
    a: 'I provide a clear estimate upfront based on the project scope and keep you updated throughout. Communication is a priority.',
  },
  {
    q: 'What is your development process?',
    a: 'I start with understanding your goals, then move into design, development, testing, and deployment — with your feedback at every stage.',
  },
  {
    q: 'Do you offer post-launch support?',
    a: 'Yes! I offer ongoing maintenance and support after the project launches to make sure everything runs smoothly.',
  },
  {
    q: 'How can I get started?',
    a: 'Just reach out via the contact section or send me an email. We can have a quick chat about your project and go from there.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section id="home" class="hero">
      <div class="hero-badge">
        <span class="badge-dot"></span> Available for freelance work
      </div>
      <h1 class="hero-title">
        Build Web Experiences<br />
        <span class="gradient-text">That Stand Out</span>
      </h1>
      <p class="hero-sub">
        Hi, I'm <strong>Ashik Elahi</strong> — a Full Stack Developer who crafts clean, fast, and beautiful websites and applications.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">View My Work</a>
        <a href="#contact" class="btn-ghost">Get In Touch →</a>
      </div>
      <div class="hero-tags">
        <span>React</span><span>Astro</span><span>Node.js</span><span>Tailwind CSS</span><span>PHP</span>
      </div>
      <!-- Hero visual -->
      <div class="hero-card-wrap">
        <div class="hero-card">
          <div class="card-header">
            <div class="dots"><span></span><span></span><span></span></div>
            <span class="card-title">portfolio.astro</span>
          </div>
          <div class="card-code">
            <div class="line"><span class="kw">const</span> <span class="var">dev</span> = {"{"}
            </div>
            <div class="line indent"><span class="str">name</span>: <span class="val">'Ashik Elahi'</span>,</div>
            <div class="line indent"><span class="str">role</span>: <span class="val">'Full Stack Dev'</span>,</div>
            <div class="line indent"><span class="str">available</span>: <span class="bool">true</span>,</div>
            <div class="line">{"}"}</div>
          </div>
          <div class="card-tags">
            <span class="ctag purple">Clean Code</span>
            <span class="ctag blue">Fast Delivery</span>
            <span class="ctag green">Open to Work</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════ EVERYTHING YOU NEED ══════════════════════ -->
    <section id="services" class="section bg-soft">
      <div class="container">
        <div class="section-label">What I Do</div>
        <h2 class="section-title">Everything You Need to<br /><span>Build a Great Web Presence</span></h2>
        <p class="section-sub">From design to deployment — I handle every layer of the stack with care.</p>
        <div class="services-grid">
          {services.map(s => (
            <div class="service-card">
              <div class="service-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════ STATS ═══════════════════════════════ -->
    <section class="stats-bar">
      <div class="container">
        <div class="stats-grid">
          {stats.map(s => (
            <div class="stat-item">
              <div class="stat-value">{s.value}</div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════ ABOUT ═══════════════════════════════ -->
    <section id="about" class="section">
      <div class="container">
        <div class="about-split">
          <div class="about-visual">
            <div class="about-avatar-wrap">
              <div class="about-avatar">AE</div>
              <div class="avatar-ring"></div>
            </div>
            <div class="about-chips">
              <div class="chip"><span>🎓</span> Self-Taught Developer</div>
              <div class="chip"><span>📍</span> Bangladesh</div>
              <div class="chip"><span>💼</span> Open to Work</div>
            </div>
          </div>
          <div class="about-text">
            <div class="section-label">About Me</div>
            <h2 class="section-title left">A Developer Who Loves<br /><span>Clean &amp; Functional Code</span></h2>
            <p>Hello! I'm <strong>Ashik Elahi</strong>, a passionate web developer from Bangladesh. I enjoy turning ideas into real, working products on the web — from designing intuitive interfaces to building robust back-end systems.</p>
            <p>I care deeply about writing maintainable code, learning new technologies, and delivering projects that make a real difference. Whether you're a startup needing a landing page or a business looking for a full web application, I've got you covered.</p>
            <div class="about-highlights">
              <div class="highlight"><div class="hl-num">3+</div><div class="hl-lbl">Years coding</div></div>
              <div class="highlight"><div class="hl-num">20+</div><div class="hl-lbl">Projects done</div></div>
              <div class="highlight"><div class="hl-num">15+</div><div class="hl-lbl">Happy clients</div></div>
            </div>
            <a href="#contact" class="btn-primary">Let's Work Together</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════ SKILLS ══════════════════════════════ -->
    <section id="skills" class="section bg-soft">
      <div class="container">
        <div class="section-label">Tech Stack</div>
        <h2 class="section-title">Pro Skills That Set Me Apart</h2>
        <p class="section-sub">Technologies I work with on a daily basis.</p>
        <div class="skills-grid">
          {skills.map(skill => (
            <div class="skill-item">
              <div class="skill-top">
                <span class="skill-name">{skill.name}</span>
                <span class="skill-pct">{skill.level}%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style={`width:${skill.level}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════ PROJECTS ══════════════════════════════ -->
    <section id="projects" class="section">
      <div class="container">
        <div class="section-label">Portfolio</div>
        <h2 class="section-title">Built for the Modern Web</h2>
        <p class="section-sub">A selection of recent projects. Update these with your real work!</p>
        <div class="projects-grid">
          {projects.map(p => (
            <div class="project-card">
              <div class="project-banner" style={`background: linear-gradient(135deg, ${p.color}22, ${p.color}44)`}>
                <div class="project-tag-pill" style={`color:${p.color}; background:${p.color}18`}>{p.tag}</div>
              </div>
              <div class="project-body">
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
                <div class="project-actions">
                  <a href={p.github} target="_blank" class="proj-link">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
                    GitHub
                  </a>
                  <a href={p.live} target="_blank" class="proj-link primary">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6.354 5.5H4a3 3 0 0 0 0 6h3a3 3 0 0 0 2.83-4H9q-.13 0-.25.031A2 2 0 0 1 7 10.5H4a2 2 0 1 1 0-4h1.535c.218-.376.495-.714.82-1zm2.208 4H10.5a3 3 0 0 0 0-6H7.5a3 3 0 0 0-2.83 4h1.098A2 2 0 0 1 7.5 5.5h3a2 2 0 1 1 0 4H9.174a4 4 0 0 1-.612 1z"/></svg>
                    Live Demo
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ FAQ ════════════════════════════════ -->
    <section class="section bg-soft">
      <div class="container faq-container">
        <div class="section-label">FAQ</div>
        <h2 class="section-title">Frequently Asked Questions</h2>
        <p class="section-sub">Everything you need to know before we work together.</p>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <details class="faq-item" name="faq">
              <summary class="faq-q">
                <span>{faq.q}</span>
                <span class="faq-icon">+</span>
              </summary>
              <div class="faq-a">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════ CONTACT CTA ═══════════════════════════ -->
    <section id="contact" class="contact-cta">
      <div class="cta-glow"></div>
      <div class="container cta-inner">
        <div class="section-label light">Let's Connect</div>
        <h2>Ready to Build Something <span>Amazing</span>?</h2>
        <p>I'm currently available for freelance projects and full-time roles. Drop me a message and let's talk about your project.</p>
        <a href="mailto:ashikelahi171810@gmail.com" class="btn-white">Say Hello 👋</a>
        <div class="cta-links">
          <a href="https://github.com/ashikelahi171810-jpg" target="_blank">GitHub</a>
          <span>·</span>
          <a href="https://linkedin.com" target="_blank">LinkedIn</a>
          <span>·</span>
          <a href="mailto:ashikelahi171810@gmail.com">ashikelahi171810@gmail.com</a>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* ═══ Base ═══ */
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section { padding: 6rem 0; }
  .bg-soft { background: var(--bg-soft); }

  .section-label {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    background: var(--accent-pale);
    padding: 0.3rem 0.9rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .section-label.light {
    color: #c4b5fd;
    background: rgba(196,181,253,0.15);
  }

  .section-title {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .section-title.left { text-align: left; }

  .section-title span { color: var(--accent); }

  .section-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .section-title:not(.left) { text-align: center; }

  /* ═══ Buttons ═══ */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.75rem;
    background: var(--accent);
    color: #fff !important;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(124,58,237,0.25);
  }

  .btn-primary:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124,58,237,0.35);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.25rem;
    color: var(--text-muted) !important;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }

  .btn-ghost:hover { color: var(--accent) !important; }

  .btn-white {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2.25rem;
    background: #fff;
    color: var(--accent) !important;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    font-size: 1.05rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.16);
  }

  /* ═══ Hero ═══ */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 5rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(124,58,237,0.09) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    background: var(--accent-pale);
    border: 1px solid rgba(124,58,237,0.2);
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 7px; height: 7px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse-dot 2s ease infinite;
  }

  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.3); }
  }

  .hero-title {
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-muted);
    max-width: 540px;
    margin: 0 auto 2rem;
    line-height: 1.8;
  }

  .hero-sub strong { color: var(--accent); }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .hero-tags span {
    padding: 0.3rem 0.85rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Hero code card */
  .hero-card-wrap {
    position: relative;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
  }

  .hero-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(124,58,237,0.05);
    overflow: hidden;
    text-align: left;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: #f9fafb;
    border-bottom: 1px solid var(--border);
  }

  .dots { display: flex; gap: 5px; }
  .dots span {
    width: 11px; height: 11px; border-radius: 50%;
  }
  .dots span:nth-child(1) { background: #ef4444; }
  .dots span:nth-child(2) { background: #f59e0b; }
  .dots span:nth-child(3) { background: #22c55e; }

  .card-title { font-size: 0.78rem; color: var(--text-muted); font-weight: 500; }

  .card-code {
    padding: 1.25rem 1.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
    line-height: 1.9;
    background: #1e1b4b;
    color: #e9d5ff;
  }

  .card-code .line { display: block; }
  .card-code .indent { padding-left: 1.5em; }
  .card-code .kw { color: #c084fc; }
  .card-code .var { color: #60a5fa; }
  .card-code .str { color: #86efac; }
  .card-code .val { color: #fcd34d; }
  .card-code .bool { color: #fb923c; }

  .card-tags {
    display: flex;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    flex-wrap: wrap;
  }

  .ctag {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .ctag.purple { background: #ede9fe; color: #7c3aed; }
  .ctag.blue   { background: #dbeafe; color: #2563eb; }
  .ctag.green  { background: #dcfce7; color: #16a34a; }

  /* ═══ Services ═══ */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .service-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: rgba(124,58,237,0.2);
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .service-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .service-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.7;
  }

  /* ═══ Stats ═══ */
  .stats-bar {
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    padding: 3.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-value {
    font-size: 2.75rem;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
  }

  /* ═══ About ═══ */
  .about-split {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: center;
  }

  .about-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .about-avatar-wrap {
    position: relative;
    width: 160px;
    height: 160px;
  }

  .about-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #2563eb);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
